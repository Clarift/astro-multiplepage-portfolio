---
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import { getPostBySlug, getAllPostSlugs } from "../../utils/getPosts";

export async function getStaticPaths() {
  const slugs = getAllPostSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/posts/");
}

const post = getPostBySlug(slug);

if (!post) {
  return Astro.redirect("/posts/");
}

const { frontmatter, Content } = post;

if (!Content) {
  console.error(`Content component not found for slug: ${slug}`);
  return Astro.redirect("/posts/");
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{frontmatter.title} - Your Portfolio</title>
    <meta name="description" content={frontmatter.description} />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "dark";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const initialTheme =
          savedTheme === "system"
            ? prefersDark
              ? "dark"
              : "light"
            : savedTheme;

        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", (e) => {
            if (localStorage.getItem("theme") === "system") {
              if (e.matches) {
                document.documentElement.classList.add("dark");
              } else {
                document.documentElement.classList.remove("dark");
              }
            }
          });

        const proseContainer = document.querySelector(".prose");
        if (proseContainer) {
          const firstH1 = proseContainer.querySelector("h1");
          if (firstH1) {
            firstH1.remove();
          }
        }
      });
    </script>
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow-x: hidden;
      }
      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      main {
        flex: 1;
      }
      section[class*="text-gray-700"] {
        margin: 0;
        padding: 0;
        flex-shrink: 0;
      }
      .prose h1:first-of-type,
      .prose > h1:first-child,
      article .prose h1:first-child {
        display: none !important;
      }

      /* Custom glowing background elements */
      .glow-orb-purple {
        background: radial-gradient(circle, rgba(147, 51, 234, 0.15) 0%, transparent 70%);
      }
      .glow-orb-teal {
        background: radial-gradient(circle, rgba(20, 184, 166, 0.1) 0%, transparent 70%);
      }

      /* Custom animations */
      @keyframes pulse-slow {
        0%, 100% { opacity: 0.8; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.05); }
      }
      .animate-pulse-slow {
        animation: pulse-slow 8s infinite ease-in-out;
      }
    </style>
  </head>
  <body class="bg-[#030014] text-neutral-100 transition-colors duration-300 relative overflow-x-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full glow-orb-purple animate-pulse-slow"></div>
      <div class="absolute top-[40%] -right-40 w-[700px] h-[700px] rounded-full glow-orb-teal animate-pulse-slow" style="animation-delay: 2s;"></div>
      <!-- Subtle dot grid pattern overlay -->
      <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:24px_24px]"></div>
    </div>

    <main class="flex-1 relative z-10">
      <Navigation />

      <article class="relative z-20 w-[896px] mx-auto mt-24 mb-12 px-7 lg:px-0">
        <header class="text-center">
          <h1
            class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl mb-4"
          >
            {frontmatter.title}
          </h1>
          <div
            class="flex items-center justify-center gap-4 text-sm text-neutral-400 mb-6 font-medium"
          >
            <time datetime={frontmatter.date || frontmatter.pubDate || ""}>
              {
                (frontmatter.date || frontmatter.pubDate)
                  ? new Date(frontmatter.date || frontmatter.pubDate).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })
                  : ""
              }
            </time>
            <span>•</span>
            <span>{frontmatter.readTime}</span>
          </div>
        </header>

        {
          frontmatter.description && (
            <p class="text-lg text-neutral-300 mb-16 text-center font-light leading-relaxed max-w-2xl mx-auto">
              {frontmatter.description}
            </p>
          )
        }

        <div class="prose prose-invert prose-purple max-w-none text-neutral-300 leading-relaxed">
          <Content />
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>
