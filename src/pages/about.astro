---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { aboutContent } from "../config/content.ts";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{aboutContent.meta.title}</title>
    <meta name="description" content={aboutContent.meta.description} />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "dark";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const initialTheme =
          savedTheme === "system"
            ? prefersDark
              ? "dark"
              : "light"
            : savedTheme;

        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", (e) => {
            if (localStorage.getItem("theme") === "system") {
              if (e.matches) {
                document.documentElement.classList.add("dark");
              } else {
                document.documentElement.classList.remove("dark");
              }
            }
          });
      });
    </script>
    <style>
      /* Custom glowing background elements */
      .glow-orb-purple {
        background: radial-gradient(circle, rgba(147, 51, 234, 0.15) 0%, transparent 70%);
      }
      .glow-orb-teal {
        background: radial-gradient(circle, rgba(20, 184, 166, 0.1) 0%, transparent 70%);
      }

      /* Custom animations */
      @keyframes pulse-slow {
        0%, 100% { opacity: 0.8; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.05); }
      }
      .animate-pulse-slow {
        animation: pulse-slow 8s infinite ease-in-out;
      }
    </style>
  </head>
  <body
    class="min-h-screen flex flex-col bg-[#030014] text-neutral-100 transition-colors duration-300 relative overflow-x-hidden"
  >
    <div class="relative flex-grow flex flex-col">
      <!-- Background glowing visual anchors -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full glow-orb-purple animate-pulse-slow"></div>
        <div class="absolute top-[40%] -right-40 w-[700px] h-[700px] rounded-full glow-orb-teal animate-pulse-slow" style="animation-delay: 2s;"></div>
        <!-- Subtle dot grid pattern overlay -->
        <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:24px_24px]"></div>
      </div>

      <Navigation />
      <section class="relative z-20 w-[896px] mx-auto mt-24 mb-12 px-6">
        <div class="relative z-20 w-full mx-auto lg:mx-0">
          <h2
            class="text-2xl font-bold tracking-tight text-white sm:text-3xl lg:text-4xl"
          >
            {aboutContent.title}
          </h2>
          <div class="flex flex-col md:flex-row gap-8 mt-3 sm:mt-4 lg:mt-6">
            <div class="w-full md:w-1/2 flex flex-col">
              <p
                class="text-sm leading-6 text-neutral-300 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg font-light"
              >
                {aboutContent.description}
              </p>
              <div class="mt-auto pt-6 flex flex-wrap gap-2">
                {
                  aboutContent.skills.map((skill) => (
                    <span class="px-3 py-1.5 text-xs bg-white/5 border border-white/10 text-neutral-200 rounded-full backdrop-blur-md">
                      {skill}
                    </span>
                  ))
                }
              </div>
            </div>
            <div class="w-full md:w-1/2 flex justify-end">
              <div class="relative w-[360px] h-[360px] rounded-xl overflow-hidden border border-white/10 shadow-2xl">
                <img
                  src={aboutContent.image.src}
                  alt={aboutContent.image.alt}
                  class="object-cover w-full h-full"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col md:flex-row mt-20 gap-8">
          <div class="flex-grow">
            <h2 class="mb-6 text-2xl font-bold text-white">
              {aboutContent.experience.title}
            </h2>
            <div class="py-4">
              {
                aboutContent.experience.items.map((item) => (
                  <div class="pb-10 border-l border-neutral-800 last:border-l-0 pl-12 relative">
                    <div class="absolute top-0 left-0 z-40 flex items-center justify-center -translate-x-1/2 bg-neutral-900 border rounded-full w-14 h-14 border-white/10 backdrop-blur-md">
                      <svg
                        class="w-6 h-6 text-purple-400"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.5"
                          d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                        />
                      </svg>
                    </div>
                    <p class="text-xs uppercase text-neutral-500 tracking-widest">
                      {item.period}
                    </p>
                    <h3 class="my-1 text-lg font-bold text-white">
                      {item.position}
                    </h3>
                    <p class="mb-1 text-sm font-semibold text-purple-300">
                      {item.company}
                    </p>
                    <p class="text-sm font-light text-neutral-400">
                      {item.description}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="w-full md:w-[320px] shrink-0">
            <h2 class="mb-6 text-2xl font-bold text-white">
              {aboutContent.connect.title}
            </h2>
            <div class="p-6 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md">
              <p
                class="text-sm leading-6 text-neutral-300 font-light"
              >
                Feel free to reach out if you want to collaborate or discuss a project. You can find me on social media or
                <a
                  href="mailto:clarift@proton.me"
                  class="text-purple-400 hover:text-purple-300 underline font-semibold transition-colors"
                >
                  send an email to clarift@proton.me
                </a>
                .
              </p>
            </div>
          </div>
        </div>
      </section>
    </div>

    <Footer />
  </body>
</html>
