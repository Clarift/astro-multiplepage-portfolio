---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { projectsContent } from "../config/content.ts";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{projectsContent.meta.title}</title>
    <meta name="description" content={projectsContent.meta.description} />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "dark";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const initialTheme =
          savedTheme === "system"
            ? prefersDark
              ? "dark"
              : "light"
            : savedTheme;

        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", (e) => {
            if (localStorage.getItem("theme") === "system") {
              if (e.matches) {
                document.documentElement.classList.add("dark");
              } else {
                document.documentElement.classList.remove("dark");
              }
            }
          });
      });
    </script>
    <style>
      /* Custom glowing background elements */
      .glow-orb-purple {
        background: radial-gradient(circle, rgba(147, 51, 234, 0.15) 0%, transparent 70%);
      }
      .glow-orb-teal {
        background: radial-gradient(circle, rgba(20, 184, 166, 0.1) 0%, transparent 70%);
      }

      /* Custom animations */
      @keyframes pulse-slow {
        0%, 100% { opacity: 0.8; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.05); }
      }
      .animate-pulse-slow {
        animation: pulse-slow 8s infinite ease-in-out;
      }
    </style>
  </head>
  <body class="bg-[#030014] text-neutral-100 transition-colors duration-300 relative overflow-x-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full glow-orb-purple animate-pulse-slow"></div>
      <div class="absolute top-[40%] -right-40 w-[700px] h-[700px] rounded-full glow-orb-teal animate-pulse-slow" style="animation-delay: 2s;"></div>
      <!-- Subtle dot grid pattern overlay -->
      <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:24px_24px]"></div>
    </div>

    <main class="flex-1 relative z-10">
      <Navigation />
      <section class="relative z-20 max-w-4xl mx-auto mt-32 mb-12 px-7 lg:px-0">
        <div class="relative z-20 w-full mx-auto lg:mx-0">
          <h2
            class="text-2xl font-bold tracking-tight text-white sm:text-3xl lg:text-4xl"
          >
            {projectsContent.title}
          </h2>
          <p
            class="mt-3 text-sm leading-6 text-neutral-300 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg font-light"
          >
            {projectsContent.description}
          </p>

          <div
            class="z-50 grid items-stretch w-full grid-cols-1 my-8 gap-7 sm:gap-5 sm:grid-cols-2 lg:grid-cols-3"
          >
            {
              projectsContent.projects.map((project) => (
                <a
                  href={project.href}
                  target="_blank"
                  class="group relative flex flex-col items-stretch p-4 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md hover:border-purple-500/30 hover:bg-white/10 hover:shadow-[0_0_20px_rgba(147,51,234,0.15)] transition-all duration-300 hover:scale-[1.03] overflow-hidden"
                >
                  <span class="block w-full overflow-hidden rounded-lg border border-white/5">
                    <img
                      src={project.image}
                      alt={project.title}
                      class="w-full h-auto aspect-[16/9] object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </span>
                  <span class="block w-full mt-4">
                    <span class="flex items-center text-base font-bold tracking-tight text-white group-hover:text-purple-300 transition-colors">
                      <span>{project.title}</span>
                      <svg
                        class="group-hover:translate-x-0.5 group-hover:-translate-y-0.5 -rotate-45 translate-y-0.5 -translate-x-0.5 w-3 h-3 stroke-current ml-1.5 transition-all ease-in-out duration-200 transform"
                        viewBox="0 0 13 15"
                      >
                        <g
                          stroke="none"
                          stroke-width="1"
                          fill="none"
                          fill-rule="evenodd"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <g
                            transform="translate(0.666667, 2.333333)"
                            stroke="currentColor"
                            stroke-width="2.4"
                          >
                            <g>
                              <polyline
                                class="transition-all duration-200 ease-out opacity-0 delay-0 group-hover:opacity-100"
                                points="5.33333333 0 10.8333333 5.5 5.33333333 11"
                              />
                              <line
                                class="transition-all duration-200 ease-out transform -translate-x-1 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 group-hover:ml-0"
                                x1="10.8333333"
                                y1="5.5"
                                x2="0.833333333"
                                y2="5.16666667"
                              />
                            </g>
                          </g>
                        </g>
                      </svg>
                    </span>
                    <span class="text-sm text-neutral-400 mt-1 block truncate">
                      {project.description}
                    </span>
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
